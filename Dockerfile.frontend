FROM node:20-alpine AS build
WORKDIR /app
COPY jxc-frontend/package*.json ./
RUN npm ci
COPY jxc-frontend/ .
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY jxc-frontend/nginx-simple.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
