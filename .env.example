# ============================================
#   JXC Production Environment Variables
#   Copy to .env and fill in real values
# ============================================

# Database Password (REQUIRED - change this!)
DB_PASSWORD=changeme

# JWT Secret (REQUIRED - must be at least 32 characters)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-this-to-a-very-long-secret-key-at-least-32-chars

# CORS Origins (comma-separated, your domain)
CORS_ORIGINS=https://your-domain.com

# Server Port
SERVER_PORT=8080

# Spring Profile
SPRING_PROFILES_ACTIVE=prod

# Domain (for SSL setup)
DOMAIN=your-domain.com
